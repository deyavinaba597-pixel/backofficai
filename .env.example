# ═══════════════════════════════════════════════════
# BackOfficeAI — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ───────────────────────────────────────────────────
# DATABASE
# ───────────────────────────────────────────────────
# Local: postgresql://postgres:yourpassword@localhost:5432/backofficai
# Neon (free): get from neon.tech
# Supabase (free): get from supabase.com
DATABASE_URL=postgresql://postgres:password@localhost:5432/backofficai

# ───────────────────────────────────────────────────
# AUTHENTICATION
# ───────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ───────────────────────────────────────────────────
# AI PROVIDER — choose one
# ───────────────────────────────────────────────────

# OPTION 1: Groq (recommended for production — free at console.groq.com)
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OPTION 2: Ollama (local development — unlimited, no key needed)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:14b

# ───────────────────────────────────────────────────
# EMAIL NOTIFICATIONS (optional)
# ───────────────────────────────────────────────────
# Free at resend.com — no credit card required
# Without this, alerts are logged to console only
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ───────────────────────────────────────────────────
# REDIS (optional — for background jobs)
# ───────────────────────────────────────────────────
# Free at upstash.com for production
# Without this, background scheduler is disabled
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────
# SERVER
# ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ───────────────────────────────────────────────────
# FRONTEND
# ───────────────────────────────────────────────────
# Local dev: http://localhost:3001/api/v1
# Production: https://your-backend.railway.app/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# CORS — frontend URL (for backend to allow)
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────
# POSTGRES (Docker only)
# ───────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=backofficai
